ENV_NAME=prod

# PostgreSQL
POSTGRES_USER=payment_verifier
POSTGRES_PASSWORD=CHANGE_ME_use_a_strong_random_password
POSTGRES_DB=payment_verifier

# Application
DATABASE_URL=postgresql+asyncpg://payment_verifier:CHANGE_ME_use_a_strong_random_password@db:5432/payment_verifier
DATABASE_URL_SYNC=postgresql+psycopg2://payment_verifier:CHANGE_ME_use_a_strong_random_password@db:5432/payment_verifier

# Port
PV_PORT=8111

# JWT
SECRET_KEY=CHANGE_ME_use_a_long_random_string
