ENV_NAME=local

# PostgreSQL
POSTGRES_USER=payment_verifier
POSTGRES_PASSWORD=payment_verifier
POSTGRES_DB=payment_verifier

# Application
DATABASE_URL=postgresql+asyncpg://payment_verifier:payment_verifier@db:5432/payment_verifier
DATABASE_URL_SYNC=postgresql+psycopg2://payment_verifier:payment_verifier@db:5432/payment_verifier

# Port
PV_PORT=8111

# JWT
SECRET_KEY=local-dev-secret-not-for-production
