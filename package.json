{
  "name": "payment-verifier-frontend",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "esbuild payment_verifier/static/ts/app.ts --bundle --outfile=payment_verifier/static/js/admin.bundle.js --format=iife --target=es2020 --minify --sourcemap",
    "build:dev": "esbuild payment_verifier/static/ts/app.ts --bundle --outfile=payment_verifier/static/js/admin.bundle.js --format=iife --target=es2020 --sourcemap",
    "watch": "esbuild payment_verifier/static/ts/app.ts --bundle --outfile=payment_verifier/static/js/admin.bundle.js --format=iife --target=es2020 --sourcemap --watch",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage"
  },
  "devDependencies": {
    "@types/node": "^25.3.5",
    "@vitest/coverage-v8": "^3.2.4",
    "esbuild": "^0.27.3",
    "jsdom": "^24.1.3",
    "typescript": "^5.8.0",
    "vitest": "^3.2.4"
  }
}
